{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mobile-mechanic-demo",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  // Standing law: every worker binds {name}.jumpstartgrowth.biz; workers.dev is
  // never customer/prospect-facing. Forks: change BOTH the name and this hostname.
  "routes": [
    { "pattern": "mobile-mechanic-demo.jumpstartgrowth.biz", "custom_domain": true }
  ]
}
